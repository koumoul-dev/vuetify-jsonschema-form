<script setup>
// @ts-nocheck

import { StatefulLayout } from '@json-layout/core/state'
import { ref, shallowRef, getCurrentInstance, useSlots, computed<% if (webmcp) { %>, watch<% } %> } from 'vue'
import { useElementSize } from '@vueuse/core'
<% if (webmcp) { %>
import { WebMCP } from '@json-layout/core/webmcp'
<% } %>
import Tree from '<%- baseImport %>/components/tree.vue'
import { useVjsf, emits } from '<%- baseImport %>/composables/use-vjsf.js'
import '<%- baseImport %>/styles/vjsf.css'

<% compImports.forEach(function({compName, compImport}){ %>
import <%= compName %> from '<%- compImport %>'
<% }); %>

<%- compiledLayoutCode %>

const nodeComponents = {
  <% compImports.forEach(function({comp, compName}){ %>
  "<%= comp %>": <%= compName %>,
  <% }); %>  
}

const props = defineProps({
  modelValue: {
    type: null,
    default: null
  },
  options: {
    /** @type import('vue').PropType<import('<%- baseImport %>/types.js').PartialVjsfOptions | null> */
    type: Object,
    default: null
  }<% if (webmcp) { %>,
  prefixName: {
    type: String,
    default: null
  },
  dataTitle: {
    type: String,
    default: null
  },
  subAgent: {
    type: Boolean,
    default: false
  }<% } %>
})

const emit = defineEmits(emits)

const { el, statefulLayout, stateTree } = useVjsf(
  null,
  computed(() => props.modelValue),
  computed(() => ({...props.options, components: <%- JSON.stringify(pluginsComponents) %>})),
  nodeComponents,
  emit,
  null,
  null,
  computed(() => compiledLayout)
)
<% if (webmcp) { %>
/** @type import('vue').ShallowRef<WebMCP | null> */
const webMCP = shallowRef(null)
watch(statefulLayout, () => {
  if (webMCP.value) webMCP.value.unregisterTools()
  if (statefulLayout.value) {
    webMCP.value = new WebMCP(
      /** @type {import('@json-layout/core').StatefulLayout} */(/** @type {unknown} */(statefulLayout.value)),
      { prefixName: props.prefixName, dataTitle: props.dataTitle, includeSubAgent: props.subAgent }
    )
    webMCP.value.registerTools()
  }
}, { immediate: true })
<% } %>
</script>

<template>
  <div
    ref="el"
    class="vjsf"
  >
    <tree
      v-if="statefulLayout && stateTree"
      :model-value="stateTree"
      :stateful-layout="statefulLayout"
    />
  </div>
</template>